---
import BaseLayout from '../layouts/BaseLayout.astro';

const quickLinks = [
  {
    href: '/dna/',
    label: 'Our DNA',
    desc: 'Vision, values, and mission',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    color: '#3A5490',
  },
  {
    href: '/teams/',
    label: 'Serve Teams',
    desc: 'Roles, expectations, and team info',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    color: '#8CC640',
  },
  {
    href: '/training/',
    label: 'Training',
    desc: 'Videos for every role and position',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    color: '#C41C35',
  },
  {
    href: '/resources/',
    label: 'Resources',
    desc: 'Documents, guides, and downloads',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
    color: '#1A2E5C',
  },
];

const teams = [
  { href: '/teams/worship/',      label: 'Worship',          icon: '🎸' },
  { href: '/teams/kid-city/',     label: 'Kid City',         icon: '🌟' },
  { href: '/teams/hospitality/',  label: 'Hospitality',      icon: '☕' },
  { href: '/teams/production/',   label: 'Production',       icon: '🎛️' },
  { href: '/teams/connections/',  label: 'First Impressions',icon: '🤝' },
];
---

<BaseLayout title="Home">
  <!-- HERO -->
  <section class="relative overflow-hidden py-20 sm:py-28" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 55%, #1A2E5C 100%);">
    <!-- Background pattern -->
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-grid" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-grid)"/>
    </svg>

    <!-- Green pill accents -->
    <div class="absolute -left-20 top-10 h-64 w-40 rounded-full opacity-10 blur-3xl" style="background: #8CC640;"></div>
    <div class="absolute -right-16 bottom-10 h-48 w-32 rounded-full opacity-8 blur-3xl" style="background: #3A5490;"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="section-label">Serve Team Portal</div>
        <h1 class="display-lg text-white mb-6">
          Welcome,<br/>
          <span style="color: #8CC640;">Team.</span>
        </h1>
        <p class="text-lg text-white/70 leading-relaxed max-w-xl">
          Everything you need to serve well at City Church Lufkin — team info, training resources, and tools all in one place.
        </p>
      </div>
    </div>
  </section>

  <!-- QUICK LINKS -->
  <section class="py-14 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 class="display-sm text-navy-800 mb-8 reveal">Quick Access</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {quickLinks.map((link, i) => (
          <a
            href={link.href}
            class={`card group block p-6 reveal delay-${(i + 1) * 100}`}
          >
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl text-white transition-transform duration-200 group-hover:scale-110" style={`background: ${link.color};`}>
              <Fragment set:html={link.icon} />
            </div>
            <h3 class="font-display text-xl font-black uppercase tracking-display text-navy-800 mb-1">{link.label}</h3>
            <p class="text-sm text-stone-500 leading-relaxed">{link.desc}</p>
            <div class="mt-4 flex items-center gap-1 text-xs font-semibold uppercase tracking-widest transition-[color,gap] duration-200 group-hover:gap-2" style="color: #8CC640;">
              Go <span>→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVE TEAMS QUICK JUMP -->
  <section class="py-12 px-4 sm:px-6 lg:px-8 border-t border-stone-200">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <div class="section-label">Find Your Team</div>
          <h2 class="display-sm text-navy-800">Serve Teams</h2>
        </div>
        <a href="/teams/" class="btn-outline self-start sm:self-auto">View All Teams</a>
      </div>

      <div class="flex flex-wrap gap-3">
        {teams.map(team => (
          <a
            href={team.href}
            class="flex items-center gap-2 rounded-full border border-stone-200 bg-white px-5 py-2.5 text-sm font-semibold text-navy-800 transition-[background,border-color,color] duration-200 hover:border-brand-green hover:bg-brand-green-light hover:text-brand-green-dark"
            style="box-shadow: 0 1px 4px rgba(16,27,46,0.06);"
          >
            <span>{team.icon}</span>
            {team.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- IMPORTANT LINK: KID CITY INCIDENT REPORT -->
  <section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="rounded-2xl overflow-hidden" style="background: #101B2E;">
        <div class="px-8 py-8 sm:px-10 flex flex-col sm:flex-row sm:items-center gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl" style="background: rgba(196,28,53,0.20);">
            <svg class="w-7 h-7" fill="none" stroke="#C41C35" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: rgba(255,255,255,0.5);">Kid City</p>
            <h3 class="font-display text-2xl font-black uppercase text-white mb-1" style="letter-spacing: 0.01em;">Incident Report Form</h3>
            <p class="text-sm" style="color: rgba(255,255,255,0.6);">Submit a report if a child is injured, sick, or involved in a behavioral incident during service.</p>
          </div>
          <a href="/teams/kid-city/incident-report/" class="shrink-0 inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-bold uppercase tracking-widest text-white transition-[background] duration-200" style="background: #C41C35;">
            File Report
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
