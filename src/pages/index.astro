---
import BaseLayout from '../layouts/BaseLayout.astro';

const quickLinks = [
  {
    href: '/dna/',
    label: 'Our DNA',
    desc: 'Vision, values, and mission',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    color: '#3A5490',
  },
  {
    href: '/teams/',
    label: 'Serve Teams',
    desc: 'Roles, expectations, and team info',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    color: '#8CC640',
  },
  {
    href: '/training/',
    label: 'Training',
    desc: 'Videos for every role and position',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    color: '#C41C35',
  },
  {
    href: '/resources/',
    label: 'Resources',
    desc: 'Documents, guides, and downloads',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
    color: '#1A2E5C',
  },
];

const teams = [
  { href: '/teams/worship/',          label: 'Worship',           icon: '🎸' },
  { href: '/teams/production/',       label: 'Media Team',        icon: '🎛️' },
  { href: '/teams/creative/',         label: 'Creative',          icon: '🎨' },
  { href: '/teams/prayer/',           label: 'Prayer Team',       icon: '🙏' },
  { href: '/teams/impressions/',      label: 'Impressions',       icon: '🤝' },
  { href: '/teams/care/',             label: 'Care Team',         icon: '❤️' },
  { href: '/teams/safety/',           label: 'Safety',            icon: '🛡️' },
  { href: '/teams/kid-city/',         label: 'Kid City',          icon: '🌟' },
  { href: '/teams/student-ministry/', label: 'Students',          icon: '⚡' },
  { href: '/teams/outreach/',         label: 'Outreach',          icon: '🌍' },
  { href: '/teams/next-steps/',       label: 'Next Steps',        icon: '👣' },
  { href: '/teams/life-groups/',      label: 'Life Groups',       icon: '🏠' },
  { href: '/teams/milestones/',       label: 'Milestones',        icon: '✝️' },
  { href: '/teams/facilities/',       label: 'Facilities',        icon: '🔧' },
];
---

<BaseLayout title="Home">

  <!-- HERO -->
  <section class="relative overflow-hidden flex flex-col justify-center" style="min-height: 78vh; background: #0A1220;">

    <!-- Dot grid -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <rect x="18" y="18" width="4" height="4" rx="1" fill="#8CC640" opacity="0.12" transform="rotate(45 20 20)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-grid)"/>
    </svg>

    <!-- Large watermark word -->
    <div class="absolute inset-0 flex items-center justify-end pointer-events-none overflow-hidden" aria-hidden="true">
      <span class="font-display font-black uppercase text-white select-none"
            style="font-size: clamp(8rem, 22vw, 20rem); letter-spacing: -0.02em; opacity: 0.025; line-height: 1; padding-right: 2rem; white-space: nowrap;">
        SERVE
      </span>
    </div>

    <!-- Green radial glow — upper left -->
    <div class="absolute pointer-events-none" style="top: -80px; left: -80px; width: 480px; height: 480px; background: radial-gradient(circle, rgba(140,198,64,0.18) 0%, transparent 70%);"></div>
    <!-- Blue radial glow — lower right -->
    <div class="absolute pointer-events-none" style="bottom: -60px; right: 0; width: 400px; height: 400px; background: radial-gradient(circle, rgba(58,84,144,0.25) 0%, transparent 70%);"></div>

    <!-- Left green border bar -->
    <div class="absolute left-0 top-0 bottom-0 w-1" style="background: linear-gradient(180deg, transparent, #8CC640 30%, #8CC640 70%, transparent);"></div>

    <div class="relative z-10 mx-auto w-full max-w-7xl px-6 sm:px-10 lg:px-16 py-20">

      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px w-10 rounded-full" style="background: #8CC640;"></div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color: rgba(140,198,64,0.8);">City Church Lufkin</span>
      </div>

      <!-- Headline -->
      <h1 class="font-display font-black uppercase text-white leading-none mb-6"
          style="font-size: clamp(3.8rem, 10vw, 8.5rem); letter-spacing: 0.01em;">
        Welcome,<br/>
        <span style="color: #8CC640; -webkit-text-stroke: 0px;">Team.</span>
      </h1>

      <!-- Divider + subtitle -->
      <div class="flex items-start gap-5 mb-10 max-w-2xl">
        <div class="shrink-0 mt-3 h-1 w-16 rounded-full" style="background: #8CC640;"></div>
        <p class="text-base sm:text-lg leading-relaxed" style="color: rgba(255,255,255,0.60);">
          Everything you need to serve well at City Church Lufkin — team info, training resources, and tools all in one place.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center gap-4 mb-16">
        <a href="/teams/" class="btn-primary">
          View All Teams
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
        <a href="/dna/" class="btn-ghost">Our DNA</a>
      </div>

      <!-- Stats strip -->
      <div class="flex flex-wrap gap-6 sm:gap-10 border-t pt-8" style="border-color: rgba(255,255,255,0.08);">
        {[
          { num: '14', label: 'Serve Teams' },
          { num: '40+', label: 'Volunteer Roles' },
          { num: '7', label: 'Church Values' },
          { num: '1', label: 'Mission' },
        ].map(stat => (
          <div>
            <p class="font-display font-black text-white leading-none mb-0.5" style="font-size: 1.75rem; letter-spacing: 0.01em;">{stat.num}</p>
            <p class="text-xs uppercase tracking-widest font-semibold" style="color: rgba(255,255,255,0.35);">{stat.label}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- QUICK LINKS -->
  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="section-label reveal">Quick Access</div>
      <h2 class="display-sm text-navy-800 mb-8 reveal">Jump To</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {quickLinks.map((link, i) => (
          <a href={link.href} class={`card group block p-6 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl text-white transition-transform duration-200 group-hover:scale-110" style={`background: ${link.color};`}>
              <Fragment set:html={link.icon} />
            </div>
            <h3 class="font-display text-xl font-black uppercase text-navy-800 mb-1" style="letter-spacing: 0.01em;">{link.label}</h3>
            <p class="text-sm text-stone-500 leading-relaxed">{link.desc}</p>
            <div class="mt-4 flex items-center gap-1 text-xs font-semibold uppercase tracking-widest transition-[gap] duration-200 group-hover:gap-2" style="color: #8CC640;">
              Go <span>→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ALL TEAMS -->
  <section class="py-14 px-4 sm:px-6 lg:px-8 border-t border-stone-200">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8 reveal">
        <div>
          <div class="section-label">Find Your Team</div>
          <h2 class="display-sm text-navy-800">All 14 Teams</h2>
        </div>
        <a href="/teams/" class="btn-outline self-start sm:self-auto">See Team Details</a>
      </div>

      <div class="flex flex-wrap gap-3 reveal delay-100">
        {teams.map(team => (
          <a
            href={team.href}
            class="flex items-center gap-2 rounded-full border border-stone-200 bg-white px-4 py-2.5 text-sm font-semibold text-navy-800 transition-[background,border-color,color,transform] duration-200 hover:border-brand-green hover:bg-brand-green-light hover:text-brand-green-dark hover:-translate-y-px"
            style="box-shadow: 0 1px 4px rgba(16,27,46,0.06);"
          >
            <span>{team.icon}</span>
            {team.label}
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
