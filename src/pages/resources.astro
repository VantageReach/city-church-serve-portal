---
import BaseLayout from '../layouts/BaseLayout.astro';

const resourceGroups = [
  {
    label: 'All Teams',
    icon: '📋',
    resources: [
      {
        title: 'Serve Team Handbook',
        desc: 'The complete guide to serving at City Church Lufkin — culture, expectations, and policies.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Volunteer Code of Conduct',
        desc: 'Standards of conduct for all City Church volunteers.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Background Check Process',
        desc: 'How to complete your background check through Ministry Safe.',
        type: 'Link',
        href: null,
      },
      {
        title: 'Service Schedule',
        desc: 'Sign up for serve slots and manage your schedule in Planning Center.',
        type: 'Link',
        href: null,
      },
    ],
  },
  {
    label: 'Kid City',
    icon: '🌟',
    resources: [
      {
        title: 'Kid City Volunteer Guidebook',
        desc: 'Everything a Kid City volunteer needs to know — curriculum, rooms, policies, and expectations.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Child Safety & Protection Policy',
        desc: 'Full policy documentation for child safety at City Church Lufkin.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Allergy & Medical Protocol',
        desc: 'How to handle allergies, medical needs, and emergencies in Kid City.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Incident Report Form',
        desc: 'File an incident report for any child injury, illness, or behavioral incident.',
        type: 'Form',
        href: '/teams/kid-city/incident-report/',
        highlight: true,
      },
    ],
  },
  {
    label: 'Worship',
    icon: '🎸',
    resources: [
      {
        title: 'Worship Team Standards & Expectations',
        desc: 'Full overview of what\'s expected of worship team members at City Church Lufkin.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Chord Chart Library',
        desc: 'Access chord charts for all songs in our current rotation.',
        type: 'Link',
        href: null,
      },
    ],
  },
  {
    label: 'Production',
    icon: '🎛️',
    resources: [
      {
        title: 'Stage Plot & Input List',
        desc: 'Standard stage plot and channel strip for the main auditorium.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'ProPresenter Template Guide',
        desc: 'How to use and update sermon slide templates in ProPresenter.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Livestream Checklist',
        desc: 'Pre-service checklist for the livestream operator.',
        type: 'PDF',
        href: null,
      },
    ],
  },
];
---

<BaseLayout title="Resources" description="Documents, guides, and tools for every serve team at City Church Lufkin.">

  <!-- HERO -->
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #1A2E5C 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-res" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-res)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="section-label">Documents & Tools</div>
      <h1 class="display-lg text-white mt-2">Resources</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Handbooks, policies, guides, and links for every team. Update links and upload files as content becomes available.</p>
    </div>
  </section>

  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-14">
      {resourceGroups.map((group, gi) => (
        <div class="reveal">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">{group.icon}</span>
            <h2 class="font-display text-2xl font-black uppercase text-navy-800" style="letter-spacing: 0.01em;">{group.label}</h2>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {group.resources.map((res, ri) => (
              res.href ? (
                <a
                  href={res.href}
                  class={`card group block p-6 reveal delay-${(ri + 1) * 100} ${res.highlight ? 'border-red-200' : ''}`}
                  style={res.highlight ? 'background: #fff5f5;' : ''}
                >
                  <div class="flex items-start justify-between gap-3">
                    <div class="flex-1">
                      <h3 class="font-semibold text-navy-800 mb-1 group-hover:text-brand-green transition-colors duration-200">{res.title}</h3>
                      <p class="text-sm text-stone-500 leading-relaxed">{res.desc}</p>
                    </div>
                    <span class={`shrink-0 rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider ${
                      res.type === 'Form'
                        ? 'text-red-600 bg-red-100'
                        : 'text-brand-green-dark bg-brand-green-light'
                    }`}>
                      {res.type}
                    </span>
                  </div>
                  <div class="mt-4 flex items-center gap-1 text-xs font-semibold uppercase tracking-widest transition-[gap] duration-200 group-hover:gap-2" style={`color: ${res.highlight ? '#C41C35' : '#8CC640'};`}>
                    Open <span>→</span>
                  </div>
                </a>
              ) : (
                <div class={`card p-6 opacity-70 reveal delay-${(ri + 1) * 100}`}>
                  <div class="flex items-start justify-between gap-3">
                    <div class="flex-1">
                      <h3 class="font-semibold text-navy-800 mb-1">{res.title}</h3>
                      <p class="text-sm text-stone-500 leading-relaxed">{res.desc}</p>
                    </div>
                    <span class="shrink-0 rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-stone-400 bg-stone-100">
                      {res.type}
                    </span>
                  </div>
                  <p class="mt-4 text-xs text-stone-400 italic">File not yet uploaded — update the href in resources.astro</p>
                </div>
              )
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
