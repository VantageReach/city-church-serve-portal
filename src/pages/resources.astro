---
import BaseLayout from '../layouts/BaseLayout.astro';

const resourceGroups = [
  {
    label: 'All Teams',
    icon: '📋',
    resources: [
      {
        title: 'Serve Team Handbook',
        desc: 'The complete guide to serving at City Church Lufkin — culture, expectations, and policies.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Volunteer Code of Conduct',
        desc: 'Standards of conduct for all City Church volunteers.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Background Check Process',
        desc: 'How to complete your background check through Ministry Safe.',
        type: 'Link',
        href: null,
      },
      {
        title: 'How to Use Planning Center Services',
        desc: 'Step-by-step video walkthrough of the Planning Center Services app — scheduling, accepting requests, and managing your serve slots.',
        type: 'Video',
        href: 'https://youtu.be/pHCyLDuMWO0?si=Bc7LZDueKrOBMXiA',
      },
      {
        title: 'Planning Center Services',
        desc: 'Sign up for serve slots, view your upcoming schedule, and accept or decline requests.',
        type: 'App',
        href: 'https://services.planningcenteronline.com',
        appLinks: {
          ios: 'https://itunes.apple.com/us/app/planning-center-services/id327370808?mt=8',
          android: 'https://play.google.com/store/apps/details?id=com.ministrycentered.PlanningCenter&hl=en',
        },
      },
      {
        title: 'Planning Center App',
        desc: 'Access People, Groups, Giving, and all Planning Center tools in one place.',
        type: 'App',
        href: 'https://app.planningcenteronline.com',
        appLinks: {
          ios: 'https://apps.apple.com/us/app/planning-center-tasks/id6751657545',
          android: 'https://play.google.com/store/apps/details?id=com.planningcenter.app&hl=en_US',
        },
      },
    ],
  },
  {
    label: 'Kid City',
    icon: '🌟',
    resources: [
      {
        title: 'Kid City Volunteer Guidebook',
        desc: 'Everything a Kid City volunteer needs to know — curriculum, rooms, policies, and expectations.',
        type: 'PDF',
        href: '/Kid_City_Guidebook_2026_v3.pdf',
      },
      {
        title: 'Child Safety & Protection Policy',
        desc: 'Full policy documentation for child safety at City Church Lufkin.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Allergy & Medical Protocol',
        desc: 'How to handle allergies, medical needs, and emergencies in Kid City.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Incident Report Form',
        desc: 'File an incident report for any child injury, illness, or behavioral incident.',
        type: 'Form',
        href: '/teams/kid-city/incident-report/',
        highlight: true,
      },
    ],
  },
  {
    label: 'Impressions',
    icon: '🤝',
    resources: [
      {
        title: 'Impressions Team Guidebook',
        desc: 'Mission, team standards, role descriptions, and expectations for all Impressions Team volunteers.',
        type: 'PDF',
        href: '/Impressions_Team_Guidebook_2026.pdf',
      },
    ],
  },
  {
    label: 'Worship',
    icon: '🎸',
    resources: [
      {
        title: 'Worship Team Standards & Expectations',
        desc: 'Full overview of what\'s expected of worship team members at City Church Lufkin.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Chord Chart Library',
        desc: 'Access chord charts for all songs in our current rotation.',
        type: 'Link',
        href: null,
      },
    ],
  },
  {
    label: 'Production',
    icon: '🎛️',
    resources: [
      {
        title: 'Stage Plot & Input List',
        desc: 'Standard stage plot and channel strip for the main auditorium.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'ProPresenter Template Guide',
        desc: 'How to use and update sermon slide templates in ProPresenter.',
        type: 'PDF',
        href: null,
      },
      {
        title: 'Livestream Checklist',
        desc: 'Pre-service checklist for the livestream operator.',
        type: 'PDF',
        href: null,
      },
    ],
  },
];
---

<BaseLayout title="Resources" description="Documents, guides, and tools for every serve team at City Church Lufkin.">

  <!-- HERO -->
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #1A2E5C 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-res" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-res)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="section-label">Documents & Tools</div>
      <h1 class="display-lg text-white mt-2">Resources</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Handbooks, policies, guides, and links for every team. Update links and upload files as content becomes available.</p>
    </div>
  </section>

  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-14">
      {resourceGroups.map((group, gi) => (
        <div class="reveal">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">{group.icon}</span>
            <h2 class="font-display text-2xl font-black uppercase text-navy-800" style="letter-spacing: 0.01em;">{group.label}</h2>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {group.resources.map((res, ri) => (
              res.href ? (
                <a
                  href={res.href}
                  class={`card group block p-6 reveal delay-${(ri + 1) * 100} ${res.highlight ? 'border-red-200' : ''}`}
                  style={res.highlight ? 'background: #fff5f5;' : ''}
                >
                  <div class="flex items-start justify-between gap-3">
                    <div class="flex-1">
                      <h3 class="font-semibold text-navy-800 mb-1 group-hover:text-brand-green transition-colors duration-200">{res.title}</h3>
                      <p class="text-sm text-stone-500 leading-relaxed">{res.desc}</p>
                    </div>
                    <span class={`shrink-0 rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider ${
                      res.type === 'Form'
                        ? 'text-red-600 bg-red-100'
                        : 'text-brand-green-dark bg-brand-green-light'
                    }`}>
                      {res.type}
                    </span>
                  </div>
                  {res.appLinks ? (
                    <div class="mt-4 flex flex-wrap gap-2">
                      <a href={res.appLinks.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-semibold text-white transition-opacity duration-200 hover:opacity-80" style="background: #101B2E;">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                        App Store
                      </a>
                      <a href={res.appLinks.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-semibold text-white transition-opacity duration-200 hover:opacity-80" style="background: #3d7a35;">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.3414c-.5511 0-.9993-.4486-.9993-.9997s.4482-.9993.9993-.9993c.5511 0 .9993.4482.9993.9993.0001.5511-.4482.9997-.9993.9997m-11.046 0c-.5511 0-.9993-.4486-.9993-.9997s.4482-.9993.9993-.9993c.5511 0 .9993.4482.9993.9993 0 .5511-.4482.9997-.9993.9997m11.4045-6.02l1.9973-3.4592a.416.416 0 00-.1521-.5676.416.416 0 00-.5676.1521l-2.0223 3.503C15.5902 8.2439 13.8533 7.8508 12 7.8508s-3.5902.3931-5.1367 1.0985L4.841 5.4467a.4161.4161 0 00-.5677-.1521.4157.4157 0 00-.1521.5676l1.9973 3.4592C2.6889 11.1867.3432 14.6589 0 18.761h24c-.3435-4.1021-2.6892-7.5743-6.1185-9.4396"/></svg>
                        Google Play
                      </a>
                      <a href={res.href} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-semibold transition-opacity duration-200 hover:opacity-80" style="background: #F0F9E0; color: #6FA32E;">
                        Web →
                      </a>
                    </div>
                  ) : (
                    <div class="mt-4 flex items-center gap-1 text-xs font-semibold uppercase tracking-widest transition-[gap] duration-200 group-hover:gap-2" style={`color: ${res.highlight ? '#C41C35' : '#8CC640'};`}>
                      Open <span>→</span>
                    </div>
                  )}
                </a>
              ) : (
                <div class={`card p-6 opacity-70 reveal delay-${(ri + 1) * 100}`}>
                  <div class="flex items-start justify-between gap-3">
                    <div class="flex-1">
                      <h3 class="font-semibold text-navy-800 mb-1">{res.title}</h3>
                      <p class="text-sm text-stone-500 leading-relaxed">{res.desc}</p>
                    </div>
                    <span class="shrink-0 rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-stone-400 bg-stone-100">
                      {res.type}
                    </span>
                  </div>
                  <p class="mt-4 text-xs text-stone-400 italic">File not yet uploaded — update the href in resources.astro</p>
                </div>
              )
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
