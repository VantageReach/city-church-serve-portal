---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamHero from '../../components/TeamHero.astro';

const roles = [
  {
    title: 'Worship Leader',
    desc: 'Guides the congregation into an encounter with God through music, Scripture, and authentic leadership. Prepares set lists, leads rehearsals, and communicates effectively with the band and team. Models a life of worship — both on stage and off.',
    win: 'The congregation is engaged, the band is confident, and people leave Sunday having genuinely encountered God.',
  },
  {
    title: 'Music Director (MD)',
    desc: 'Supports the worship leader in the musical execution of Sunday services, ensuring the band is prepared, tight, and fully serving the music. Leads and directs the band during rehearsals and services, arranges charts, communicates keys and tempos, and helps develop and coach other musicians.',
    win: 'The band plays as one unit, transitions are smooth, and every musician feels supported and set up to do their best.',
  },
  {
    title: 'Vocalist',
    desc: 'Supports the worship experience through harmony and depth. Attends all scheduled rehearsals and services prepared, on time, and ready to serve. Sings with excellence and a heart of worship, supporting — not competing with — the lead vocal.',
    win: 'Harmonies are solid, the sound is full, and the team feels unified in heart and voice.',
  },
  {
    title: 'Instrumentalist — Guitar',
    desc: 'Serves the worship experience through musical excellence. Prepares parts before rehearsal — knows the charts and songs before arriving. Serves the song and the moment, playing with excellence and restraint. On time, coachable, and encouraging to those around them.',
    win: 'The music supports the worship environment without distraction, and every song lands exactly as intended.',
  },
  {
    title: 'Instrumentalist — Drums',
    desc: 'Anchors the rhythmic foundation of the worship team. Prepares parts before rehearsal, serves the song and the moment, and keeps time for the full team. On time, coachable, and encouraging to those around them.',
    win: 'The band locks in, tempo is consistent, and the music carries the room.',
  },
  {
    title: 'Instrumentalist — Keys / Piano',
    desc: 'Provides harmonic depth and texture to the worship sound. Prepares patches and parts before rehearsal, serves the song and the moment with excellence and restraint. On time, coachable, and encouraging to those around them.',
    win: 'The music supports the worship environment without distraction, and every song lands exactly as intended.',
  },
  {
    title: 'Instrumentalist — Bass',
    desc: 'Serves the groove and foundation of the band. Prepares parts before rehearsal, locks in with the drummer, and plays with excellence and restraint. On time, coachable, and encouraging to those around them.',
    win: 'The bottom end is solid, the band feels locked in, and the music carries people into worship.',
  },
];

const trainingVideos = [
  { title: 'Worship Team Orientation' },
  { title: 'Vocalist Training & Standards' },
  { title: 'Band Culture & Expectations' },
  { title: 'Rehearsal Process Walkthrough' },
];

const expectations = [
  'Arrive at your scheduled call time — not service time.',
  'Come prepared. Know the songs and charts before rehearsal begins.',
  'Be submitted and coachable under the Worship Director and Worship Leader.',
  'Serve with a worshiper\'s heart, not just a musician\'s skill.',
  'Communicate early if you can\'t make it — give at least one week\'s notice.',
  'Represent the worship team with humility both on and off the stage.',
  'Model a life of worship — what you carry into the room matters.',
];
---

<BaseLayout title="Worship Team" description="Leading City Church Lufkin into an encounter with God through music, song, and authentic worship.">
  <TeamHero
    title="Worship"
    emoji="🎸"
    subtitle="Leading the church into the presence of God through music, song, and authentic worship."
    gradientEnd="#3A5490"
    patternId="dot-worship"
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <!-- ABOUT -->
    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The Worship Team leads all things worship at City Church — from Sunday morning music to the overall culture of encounter we build week after week. We are not a performance team; we are guides. Our job is to create space for people to meet God, and that starts long before we step on the stage. If you are on this team, you carry something — and what you carry matters. We build, develop, and shepherd a culture of authentic worship where excellence and surrender work together.
      </p>
    </div>

    <!-- EXPECTATIONS -->
    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <!-- ROLES -->
    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- TRAINING VIDEOS -->
    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg bg-stone-100 aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
