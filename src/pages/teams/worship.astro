---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Worship Leader',
    desc: '[Describe the responsibilities of the Worship Leader — song selection, leading rehearsal, shepherding the team spiritually, communicating with the pastor, etc.]',
  },
  {
    title: 'Vocalist',
    desc: '[Describe the vocalist role — harmony responsibilities, preparation expectations, microphone etiquette, serving under the worship leader, etc.]',
  },
  {
    title: 'Guitarist (Lead & Rhythm)',
    desc: '[Describe what\'s expected of guitarists — charts, amps, gear, rehearsal prep, and communication with production.]',
  },
  {
    title: 'Bassist',
    desc: '[Describe the bassist role — serving the groove, communication with drummer, direct in vs. amp, DI box setup, etc.]',
  },
  {
    title: 'Drummer',
    desc: '[Describe drummer expectations — in-ear mix, click track, kit setup, tear down, keeping time for the team, etc.]',
  },
  {
    title: 'Keys / Piano',
    desc: '[Describe keys role — patches, pads, split responsibilities, serving the song, communication with worship leader, etc.]',
  },
];

const trainingVideos = [
  { title: 'Worship Leader Orientation', placeholder: true },
  { title: 'Vocalist Training', placeholder: true },
  { title: 'Band Culture & Expectations', placeholder: true },
  { title: 'Rehearsal Process Walkthrough', placeholder: true },
];

const expectations = [
  'Arrive at your scheduled call time — not service time.',
  'Come prepared. Know the songs before rehearsal.',
  'Be submitted and coachable under the Worship Leader.',
  'Serve with a worshiper\'s heart, not just a musician\'s skill.',
  'Communicate early if you can\'t make it. Give at least one week\'s notice.',
  'Keep your gear maintained and ready to go each Sunday.',
];
---

<BaseLayout title="Worship Team">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #3A5490 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-worship" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-worship)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">🎸 Worship</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Leading the church into the presence of God through music and song.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <!-- ABOUT -->
    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        [Replace with a short paragraph about the worship team at City Church Lufkin — the heart behind the team, what you value musically and spiritually, and who this team is for.]
      </p>
    </div>

    <!-- EXPECTATIONS -->
    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <!-- ROLES -->
    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed">{role.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- TRAINING VIDEOS -->
    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg bg-stone-100 aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
