---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Coffee Team',
    desc: 'Creates a warm and welcoming atmosphere through quality coffee and genuine hospitality before and after services. Sets up, brews, and serves coffee efficiently. Keeps the coffee area clean, stocked, and inviting throughout the morning. Engages warmly with everyone nearby — coffee is the tool; connection is the ministry.',
    win: 'The coffee area is a hub of warmth and conversation. People linger, connect, and feel right at home.',
  },
  {
    title: 'Experience Team — Design, Décor & Atmosphere',
    desc: 'Curates the physical atmosphere of City Church — the aesthetics, décor, and environments that make every person feel like someone prepared this space just for them. Designs and sets up décor and environmental elements for Sunday services and special events. Works with leadership to ensure all spaces reflect City Church\'s culture and brand. Finds creative, budget-conscious ways to elevate the atmosphere of every environment.',
    win: 'People walk in and immediately feel that this place is special. The environment communicates: you are expected, you are welcome, you belong here.',
  },
  {
    title: 'Care Team',
    desc: 'Serves the City Church family through practical expressions of love — meals, cards, calls, and presence during life\'s hardest moments. Responds to care needs in the congregation — illness, loss, new babies, and life transitions. Coordinates meals, cards, and practical support for members who need it.',
    win: 'Every member of City Church who walks through a hard season feels genuinely cared for and covered by their church family. Nobody walks through anything alone.',
  },
];

const trainingVideos = [
  { title: 'Hospitality Team Orientation' },
  { title: 'Coffee Bar Setup & Service' },
  { title: 'Creating an Atmosphere of Welcome' },
  { title: 'Care Team: Practical Love in Action' },
];

const expectations = [
  'Arrive early enough to have your area fully set up before doors open.',
  'Be the warmest presence in the room — your energy sets the tone.',
  'Keep your station clean, stocked, and inviting throughout the service.',
  'Proactively look for guests who seem lost or unsure and direct them warmly.',
  'Know the basics: service times, Kid City location, how to connect someone to a Life Group.',
  'Coffee is the tool — genuine connection with people is the ministry.',
  'Communicate any supply needs to your team lead before Sunday, not during.',
];
---

<BaseLayout title="Hospitality Team" description="Making every person who walks through City Church Lufkin's door feel welcome, seen, and at home.">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #5C3A1E 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-hosp" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-hosp)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">☕ Hospitality</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Making every person who walks through the door feel welcome, seen, and at home.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The Hospitality team creates the atmosphere and culture of warmth that City Church is known for. This team serves through coffee, through creating beautiful spaces, and through showing up for people in their hardest moments. We believe hospitality is not just a function — it is a form of ministry. When someone walks into a room we've prepared, or wraps their hands around a cup of coffee we've made, or receives a meal when life has fallen apart — they are experiencing the love of God through the hands of the church.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
