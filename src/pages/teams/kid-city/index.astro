---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Kids Check-In',
    desc: 'The first point of contact for families in Kid City — welcoming parents and children with warmth and checking every child in safely and efficiently. Arrives early and has the check-in system ready before families arrive. Checks in every child accurately, prints labels, and ensures parents receive security tags. Welcomes families warmly and helps new families navigate Kid City with ease and confidence.',
    win: 'Every family gets checked in quickly and correctly. Parents feel safe leaving their kids, and children leave the check-in table excited to go to class.',
  },
  {
    title: 'Kid City Teacher — Elementary (Ages 5–11)',
    desc: 'Leads elementary-aged children through age-appropriate lessons, helping them discover who Jesus is and how to live for Him. Prepares and teaches the weekly lesson with energy, creativity, and clarity. Creates a safe, fun, and engaging classroom environment where every child feels seen. Prays for and invests in the children in their class beyond Sunday morning.',
    win: 'Kids leave class knowing what they learned, having had fun, and feeling genuinely known by their teacher. Over time, the Word is taking root.',
  },
  {
    title: 'Kid City Media Helper — Elementary',
    desc: 'Supports the elementary classroom by running ProPresenter slides, videos, and media elements that support the lesson. Runs slides, videos, and media in sync with the teacher and lesson flow. Keeps the tech running smoothly so the teacher can focus entirely on the kids. Reviews the lesson content before class so they can anticipate what\'s coming.',
    win: 'The teacher never has to worry about tech. Every video plays, every slide is on cue, and class flows without interruption.',
  },
  {
    title: 'Kid City Helper — Elementary',
    desc: 'Assists the teacher in managing the classroom, engaging kids, and ensuring a safe, fun, and welcoming environment. Assists with classroom management, activities, and small group moments. Builds relationships with the kids — learns their names and their stories. Helps maintain a safe, orderly environment where every child feels welcome.',
    win: 'The teacher feels fully supported, kids are engaged and safe, and helpers are building real relationships with the next generation.',
  },
  {
    title: 'Room Leader — Nursery, Toddlers & Pre-School',
    desc: 'Oversees a specific age room (birth–4 years), leading helpers and ensuring every child is safe, engaged, and well cared for. Leads the helpers in their room and ensures adequate coverage for the children present. Creates a nurturing, age-appropriate environment where every child feels comfortable and safe. Communicates any needs, incidents, or concerns to the Mini City Coordinator.',
    win: 'Every child in your room is safe, happy, and engaged. Parents pick up their children to big smiles and a positive report.',
  },
  {
    title: 'Teacher & Helper — Nursery, Toddlers & Pre-School',
    desc: 'Serves the youngest members of City Church with love, patience, and intentional care. Cares for children with warmth, attentiveness, and a genuine servant heart. Follows all safe environment policies, including check-in/check-out procedures at all times. Assists the Room Leader with activities, diaper changes, and all general care needs.',
    win: 'Every child is cared for as if they were your own. Parents come back every week because they trust their children are safe and deeply loved.',
  },
];

const trainingVideos = [
  { title: 'Kid City Volunteer Orientation' },
  { title: 'Child Safety & Protection Policy' },
  { title: 'Check-In System Training (Planning Center)' },
  { title: 'Classroom Management' },
  { title: 'Nursery & Mini City Best Practices' },
  { title: 'Elementary Room Leader Training' },
];

const expectations = [
  'Arrive 20 minutes early for check-in setup and room prep.',
  'You are background-checked and approved before serving with children — no exceptions.',
  'Two-adult rule: two unrelated adults must always be present in any room with children.',
  'Never be alone with a child — this protects both the child and you.',
  'Follow all check-in and check-out procedures every service, every time.',
  'Know your room\'s allergy and medical information before service begins.',
  'Report any incident (injury, illness, behavioral) immediately — use the incident report process.',
  'Keep your phone away during service — your full attention belongs to the kids.',
  'Be consistent. Kids and families are counting on you to show up.',
];
---

<BaseLayout title="Kid City Team" description="Reaching the next generation — creating safe, fun, and transformative environments for every child at City Church Lufkin.">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #4A7A1E 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-kc" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.12" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-kc)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">🌟 Kid City</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Reaching the next generation — creating a safe, fun, and transformative environment for every child at City Church Lufkin.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <!-- INCIDENT REPORT CALLOUT -->
    <div class="reveal">
      <div class="rounded-2xl overflow-hidden" style="background: #101B2E;">
        <div class="px-7 py-6 flex flex-col sm:flex-row sm:items-center gap-5">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl" style="background: rgba(196,28,53,0.20);">
            <svg class="w-6 h-6" fill="none" stroke="#C41C35" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="font-display text-xl font-black uppercase text-white mb-0.5" style="letter-spacing: 0.01em;">Incident Report</h3>
            <p class="text-sm" style="color: rgba(255,255,255,0.55);">If a child is injured, sick, or involved in a behavioral incident, file a report immediately.</p>
          </div>
          <a href="/teams/kid-city/incident-report/" class="shrink-0 inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-bold uppercase tracking-widest text-white transition-[background] duration-200" style="background: #C41C35;">
            File Report
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ABOUT -->
    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        Kid City is City Church's children's ministry for birth through 5th grade. Our goal is simple: kids show up excited, parents drop off their children with full confidence, and Kid City is a front door for families in Lufkin. We build safe, fun, and spiritually transformative environments where kids encounter Jesus, grow in their faith, and make church their favorite place to be. Every volunteer in these rooms plays a direct role in the spiritual formation of the next generation.
      </p>
    </div>

    <!-- AGE ROOMS -->
    <div class="reveal">
      <div class="section-label">Our Rooms</div>
      <h2 class="display-sm text-navy-800 mb-6">Who We Serve</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        {[
          { room: 'Baby Blvd', ages: 'Newborn – 12 mo' },
          { room: 'Toddler Trail', ages: '1–2 Years' },
          { room: 'Preschool Place', ages: '3–4 Years' },
          { room: 'Pre-K City', ages: 'Pre-K' },
          { room: 'Kid City', ages: 'K–5th Grade' },
          { room: 'Check-In', ages: 'All Ages' },
        ].map((room) => (
          <div class="card p-4 text-center">
            <p class="font-display text-base font-black uppercase text-navy-800 mb-1" style="letter-spacing: 0.01em;">{room.room}</p>
            <p class="text-xs text-stone-500">{room.ages}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- EXPECTATIONS -->
    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <!-- ROLES -->
    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- TRAINING VIDEOS -->
    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
