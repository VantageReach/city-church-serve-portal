---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Greeter — Front Door, Lobby & Outside',
    desc: 'The first face of City Church — welcoming every person with a smile, genuine warmth, and the message: You belong here. In position before the service begins. Greets guests and regulars with warmth, eye contact, and authentic friendliness. Helps first-time guests find what they need — restrooms, Kid City, coffee, seating.',
    win: 'Every person who walks through the door feels genuinely welcomed — not just handed a program, but actually seen and treated like family.',
  },
  {
    title: 'Usher',
    desc: 'Serves the congregation during the service — helping seat people, facilitating the offering, and managing the auditorium experience with care and professionalism. Helps seat guests and latecomers with minimal disruption. Facilitates the offering, communion, and any in-service needs with excellence. Stays attentive throughout the service.',
    win: 'The auditorium runs smoothly. People are comfortable, the offering flows naturally, and anyone who needs help can always find it.',
  },
  {
    title: 'Connections Table',
    desc: 'The go-to resource for first-time guests and members exploring their next step — helping people find their place at City Church. Staffs the connections table before and after services, ready to answer questions and provide resources. Knows City Church\'s Next Steps pathway and explains it clearly to brand-new guests. Connects interested guests with the right person or resource.',
    win: 'Every first-time guest who visits the connections table leaves with a clear next step and a personal connection to someone at City Church.',
  },
  {
    title: 'Impressions Team Lead',
    desc: 'Oversees all front-door volunteers — greeters, ushers, the connections table, and the coffee team — ensuring every person who walks in feels immediately welcomed. Leads and coordinates all Impressions volunteers before and during services. Casts the vision for first impressions and ensures every team member understands the why behind their role.',
    win: 'Every guest\'s first experience at City Church is warm, welcoming, and memorable. Nobody slips through unnoticed.',
  },
];

const trainingVideos = [
  { title: 'First Impressions Team Orientation' },
  { title: 'The Art of Making Someone Feel Welcome' },
  { title: 'How to Spot and Engage a First-Time Guest' },
  { title: 'Connections Table Training' },
];

const expectations = [
  'Arrive 30 minutes before service to take your position.',
  'Smile, make eye contact, and initiate — don\'t wait for people to come to you.',
  'You are often the first (and last) experience someone has at City Church.',
  'Know the basics: Kid City location, restrooms, coffee area, connections table, service times.',
  'Look for the person standing alone — they are your priority.',
  'Stay engaged and alert throughout the pre- and post-service window.',
  'Know City Church\'s Next Steps pathway so you can point people in the right direction.',
];
---

<BaseLayout title="First Impressions Team" description="The first face people see at City Church Lufkin — setting the tone for every person's entire experience.">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #4A1E7A 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-conn" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-conn)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">🤝 First Impressions</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">The first face people see when they arrive at City Church — you set the tone for their entire experience.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The First Impressions team is the front door of City Church Lufkin. Before anyone hears a song or a message, they experience us — our warmth, our attention, our genuine care. This team's job is to make sure that every single person who walks through our doors feels expected, welcomed, and like they belong here. We believe church should feel like family the moment you arrive, and that starts with the people standing at the door. You are not just a volunteer — you are the face of City Church.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
