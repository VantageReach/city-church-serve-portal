---
import BaseLayout from '../../layouts/BaseLayout.astro';

const teams = [
  {
    href: '/teams/worship/',
    label: 'Worship',
    tagline: 'Leading the church into God\'s presence',
    icon: '🎸',
    color: '#3A5490',
    roles: ['Worship Leader', 'Music Director', 'Vocalist', 'Instrumentalist'],
  },
  {
    href: '/teams/kid-city/',
    label: 'Kid City',
    tagline: 'Reaching the next generation',
    icon: '🌟',
    color: '#8CC640',
    roles: ['Kids Check-In', 'Elementary Teacher', 'Room Leader', 'Helper'],
    hasIncidentReport: true,
  },
  {
    href: '/teams/hospitality/',
    label: 'Hospitality',
    tagline: 'Making everyone feel at home',
    icon: '☕',
    color: '#C9782A',
    roles: ['Coffee Team', 'Experience Team', 'Care Team'],
  },
  {
    href: '/teams/production/',
    label: 'Production',
    tagline: 'Serving behind the scenes',
    icon: '🎛️',
    color: '#1A2E5C',
    roles: ['Sound Tech', 'Presentation Operator', 'Live Stream Director', 'Camera Operator'],
  },
  {
    href: '/teams/connections/',
    label: 'First Impressions',
    tagline: 'The first face people see',
    icon: '🤝',
    color: '#7A3E9D',
    roles: ['Greeter', 'Usher', 'Connections Table', 'Impressions Team Lead'],
  },
  {
    href: '/teams/prayer/',
    label: 'Prayer Team',
    tagline: 'Covering every service in prayer',
    icon: '🙏',
    color: '#2E1A5C',
    roles: ['Pre-Service Prayer', 'Altar Team', 'Prayer Request Team'],
  },
  {
    href: '/teams/creative/',
    label: 'Creative Team',
    tagline: 'Telling the City Church story',
    icon: '🎨',
    color: '#2E5C3A',
    roles: ['Capture (Photo & Video)', 'Create (Graphics)', 'Convey (Social & Email)'],
  },
  {
    href: '/teams/safety/',
    label: 'Safety Team',
    tagline: 'Keeping every guest safe',
    icon: '🛡️',
    color: '#5C1A1A',
    roles: ['Safety Team Lead', 'Medical Team', 'Security'],
  },
  {
    href: '/teams/student-ministry/',
    label: 'Student Ministry',
    tagline: 'Reaching Jr High & High School students',
    icon: '⚡',
    color: '#3A2E5C',
    roles: ['Student Ministry Leader', 'Student Ministry Volunteer'],
  },
  {
    href: '/teams/outreach/',
    label: 'Outreach',
    tagline: 'A giving, going church',
    icon: '🌍',
    color: '#1A4A2E',
    roles: ['Global Outreach Lead', 'Serve Weekend Volunteer'],
  },
  {
    href: '/teams/next-steps/',
    label: 'Next Steps',
    tagline: 'Connecting new people to the family',
    icon: '👣',
    color: '#4A3A1A',
    roles: ['Event Coordinator', 'Greeter / Helper'],
  },
  {
    href: '/teams/life-groups/',
    label: 'Life Groups',
    tagline: 'Where people belong and grow',
    icon: '🏠',
    color: '#1A3A5C',
    roles: ['Life Group Leader', 'Discipleship', 'Recovery', 'Freedom Groups'],
  },
  {
    href: '/teams/milestones/',
    label: 'Milestones',
    tagline: 'Honoring the sacred moments',
    icon: '✝️',
    color: '#1A4A4A',
    roles: ['Water Baptism Team', 'Communion Team'],
  },
  {
    href: '/teams/facilities/',
    label: 'Facilities',
    tagline: 'Keeping the building ready for ministry',
    icon: '🔧',
    color: '#3A3A1A',
    roles: ['Cleaning Team', 'Lawn Care', 'Building Repair & Upkeep'],
  },
];
---

<BaseLayout title="Serve Teams">

  <!-- HERO -->
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #1A2E5C 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-grid-teams" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-grid-teams)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="section-label">Get Involved</div>
      <h1 class="display-lg text-white mt-2">Serve <span style="color: #8CC640;">Teams</span></h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Click any team to see their expectations, roles, and training resources.</p>
    </div>
  </section>

  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {teams.map((team, i) => (
          <a
            href={team.href}
            class={`card group block p-7 reveal delay-${(i + 1) * 100}`}
          >
            <div class="flex items-start justify-between mb-5">
              <div class="flex h-14 w-14 items-center justify-center rounded-xl text-2xl transition-transform duration-200 group-hover:scale-110" style={`background: ${team.color}18;`}>
                {team.icon}
              </div>
              {team.hasIncidentReport && (
                <span class="rounded-full px-3 py-1 text-xs font-bold uppercase tracking-widest" style="background: rgba(196,28,53,0.10); color: #C41C35;">
                  Incident Form
                </span>
              )}
            </div>

            <h2 class="font-display text-2xl font-black uppercase text-navy-800 mb-1" style="letter-spacing: 0.01em;">{team.label}</h2>
            <p class="text-sm text-stone-500 mb-5">{team.tagline}</p>

            <div class="flex flex-wrap gap-2 mb-6">
              {team.roles.slice(0, 4).map(role => (
                <span class="rounded-full border border-stone-200 bg-stone-50 px-3 py-1 text-xs font-medium text-stone-600">
                  {role}
                </span>
              ))}
              {team.roles.length > 4 && (
                <span class="rounded-full border border-stone-200 bg-stone-50 px-3 py-1 text-xs font-medium text-stone-400">
                  +{team.roles.length - 4} more
                </span>
              )}
            </div>

            <div class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest transition-[gap] duration-200 group-hover:gap-2.5" style="color: #8CC640;">
              View Team
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
