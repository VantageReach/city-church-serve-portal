---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamHero from '../../components/TeamHero.astro';
import TeamResources from '../../components/TeamResources.astro';

const roles = [
  {
    title: 'Care Team',
    desc: 'Serves the City Church family through practical expressions of love — meals, cards, calls, and presence during life\'s hardest moments. Responds to care needs in the congregation — illness, loss, new babies, and life transitions. Coordinates meals, cards, and practical support for members who need it. Reaches out with intentionality and compassion to let people know the church family sees them and is with them.',
    win: 'Every member of City Church who walks through a hard season feels genuinely cared for and covered by their church family. Nobody walks through anything alone.',
  },
];


const expectations = [
  'Respond promptly when a care need is communicated — timing matters in these moments.',
  'Lead with compassion, not advice — presence is often more valuable than words.',
  'Maintain confidentiality in every care situation.',
  'Coordinate practically: confirm meal drop-offs, follow up, don\'t assume someone else handled it.',
  'Know when a need exceeds what a care team can provide — refer to pastoral staff.',
  'Let people know they are seen and that the City Church family is with them.',
  'Keep a servant\'s posture — this ministry happens behind the scenes, not on a stage.',
];
---

<BaseLayout title="Care Team" description="The City Church Lufkin Care Team — serving our church family through practical expressions of love during life's hardest moments.">

  <TeamHero
    title="Care Team"
    emoji="❤️"
    subtitle="Serving the City Church family through practical love — meals, presence, and care during life's hardest moments."
    gradientEnd="#5C1A3A"
    patternId="dot-care"
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The Care Team is the hands and feet of the City Church family during the moments that matter most. When someone receives a diagnosis, loses a loved one, brings home a new baby, or walks through a season of hardship — this team shows up. Not with programs, but with meals, cards, phone calls, and presence. We believe the church should be the first place people turn when life gets hard, and the Care Team is what makes that real.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs font-semibold italic" style="color: #6FA32E;">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>


    <TeamResources team="care" />

  </div>
</BaseLayout>
