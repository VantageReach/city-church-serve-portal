---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Capture — Photo & Video',
    desc: 'Documents the life of City Church through photography and videography, providing content that tells our story across social media, print, and communications. Captures high-quality photos and videos at Sunday services and church events. Delivers edited content in a timely manner for use by the Convey team. Represents City Church with professionalism and creativity behind the lens.',
    win: 'City Church always has fresh, high-quality visual content that tells our story and invites people in.',
  },
  {
    title: 'Create — Graphics & Video',
    desc: 'Produces all graphics, videos, and visual assets for City Church — from sermon series artwork to event promotions and social content. Designs graphics and produces video content that reflects City Church\'s brand and culture. Completes design requests on time and in alignment with the church\'s communication calendar. Collaborates with the Worship Director and Lead Pastors on visual direction for sermon series and events.',
    win: 'City Church looks excellent and consistent across every platform, and creative assets are always done before the deadline.',
  },
  {
    title: 'Convey — Social & Email',
    desc: 'Manages City Church\'s social media channels and email communications, keeping the church family and community informed, engaged, and inspired. Posts consistent, on-brand content to City Church social media channels on a regular schedule. Writes and sends church emails — newsletters, announcements, and follow-ups — on time. Engages warmly with comments, messages, and interactions in a timely and pastoral way.',
    win: 'People always know what\'s happening at City Church. New people discover us online, and our presence is consistent and life-giving.',
  },
];

const trainingVideos = [
  { title: 'Creative Team Orientation' },
  { title: 'Photo & Video Standards' },
  { title: 'Graphic Design Brand Guide' },
  { title: 'Social Media & Email Calendar' },
];

const expectations = [
  'Deliver content on time — creative work with a late deadline serves no one.',
  'Know and protect the City Church brand: colors, fonts, tone, and feel.',
  'Communicate proactively if a deadline is at risk — never let it slip silently.',
  'Represent City Church with professionalism and creativity in every piece.',
  'Capture moments that tell the story — don\'t just document, help people feel it.',
  'Engage with social interactions in a warm, pastoral tone — not just a posting schedule.',
];
---

<BaseLayout title="Creative Team" description="Telling the City Church Lufkin story through photography, video, graphics, and social media.">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #2E5C3A 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-creative" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-creative)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">🎨 Creative Team</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Telling the City Church story through photography, video, graphics, and social media.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The Creative Team tells the City Church story — through a camera lens, a well-designed graphic, or a timely social post. What we create shapes how people perceive City Church before they ever walk in the door, and how the church family stays connected throughout the week. This team includes photographers, videographers, graphic designers, and the people behind our social media and email channels. If you have a creative gift, this is how you put it to work for the Kingdom.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
