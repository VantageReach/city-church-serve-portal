---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamHero from '../../components/TeamHero.astro';

const roles = [
  {
    title: 'Water Baptism Team',
    desc: 'Facilitates the significant spiritual moment of Water Baptism with care, intentionality, and excellence. Prepares all logistics for baptism services — water, robes, towels, forms, and setup. Walks each baptism candidate through the process with warmth and personal encouragement. Celebrates and documents every baptism as the milestone moment it truly is.',
    win: 'Every baptism is a moment. It\'s personal, it\'s celebrated, and the person knows exactly what they\'re stepping into.',
  },
  {
    title: 'Communion Team',
    desc: 'Prepares and serves Communion with reverence, warmth, and a heart that honors the significance of the table. Prepares and sets up all communion elements for every service it is offered. Serves communion with reverence, warmth, and a heart that honors the significance of the table. Ensures all elements are fresh, accessible, and sufficient for the full congregation.',
    win: 'Communion feels sacred and meaningful. Every person who participates encounters the table with intention and leaves changed.',
  },
];

const trainingVideos = [
  { title: 'Milestones Team Orientation' },
  { title: 'Water Baptism: Setup & Candidate Care' },
  { title: 'Communion: Setup & Service' },
  { title: 'The Theology Behind the Milestones' },
];

const expectations = [
  'Arrive early — milestone moments require everything to be ready before people arrive.',
  'Handle every element with care and reverence; these are sacred moments.',
  'Walk with baptism candidates personally — they should never feel alone in this moment.',
  'Ensure all supplies are stocked, fresh, and sufficient before the service begins.',
  'Communicate any supply needs or issues to leadership before Sunday, not during.',
  'Celebrate every baptism — make it feel like the milestone it truly is.',
];
---

<BaseLayout title="Milestones Team" description="Facilitating the significant spiritual moments of Water Baptism and Communion at City Church Lufkin.">
  <TeamHero
    title="Milestones"
    emoji="✝️"
    subtitle="Facilitating the sacred moments of Water Baptism and Communion with care and intentionality."
    gradientEnd="#1A4A4A"
    patternId="dot-milestones"
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The Milestones team serves at the most sacred moments in the life of City Church — Water Baptism and Communion. These are not logistics problems to be managed; they are holy moments to be honored. Every baptism represents a life changed. Every communion table is an encounter with the sacrifice of Jesus. The people who serve on this team understand the weight of what they're doing, and they give every detail the care and reverence it deserves.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
