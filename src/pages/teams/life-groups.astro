---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Life Group Leader',
    desc: 'Hosts and facilitates small group community — creating a space where people grow in their faith and build real relationships. This role covers Recovery Groups, Discipleship Groups, Interest Groups, and Freedom Groups. Leads the group consistently — meeting regularly and following up with members between gatherings. Facilitates discussion, prayer, and community that helps people take their next step spiritually. Communicates with the Connections Director about the group\'s health, needs, and wins.',
    win: 'Your group is a place where people truly belong. Relationships are real, people are growing, and nobody feels alone in their walk with God.',
  },
];

const groupTypes = [
  { name: 'Discipleship Groups', desc: 'Deep-dive Bible study and spiritual formation for committed followers.' },
  { name: 'Recovery Groups', desc: 'Safe, grace-filled community for people overcoming addiction, loss, or life challenges.' },
  { name: 'Interest Groups', desc: 'Connection around shared hobbies, seasons of life, or interests — where friendships form.' },
  { name: 'Freedom Groups', desc: 'Focused groups for people pursuing emotional healing and spiritual freedom.' },
];

const trainingVideos = [
  { title: 'Life Group Leader Orientation' },
  { title: 'How to Facilitate a Great Discussion' },
  { title: 'Pastoral Care in Small Groups' },
  { title: 'Growing and Multiplying Your Group' },
];

const expectations = [
  'Meet consistently — your group depends on your reliability and follow-through.',
  'Follow up with group members between gatherings; relationships grow outside of meetings.',
  'Create an environment where everyone feels safe, known, and valued.',
  'Facilitate discussion — you are a guide, not a lecturer.',
  'Communicate group health, needs, and wins to the Connections Director regularly.',
  'Know when a need exceeds what a small group can handle — refer people to pastoral staff.',
  'Lead from a place of growth yourself — the best leaders are always growing.',
];
---

<BaseLayout title="Life Groups" description="Small group community at City Church Lufkin — where people grow, belong, and do life together.">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #1A3A5C 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-groups" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-groups)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">🏠 Life Groups</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Where people grow, belong, and do life together — in every season.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        Life Groups are where the church gets personal. Sunday morning brings us together — Life Groups are where we actually know each other. Life Group Leaders open their homes, their lives, and their time to create spaces where people can ask real questions, share real struggles, and experience real community. Whether you're leading a discipleship group, a recovery group, or a connection group around a shared interest, the goal is the same: nobody walking through life alone.
      </p>
    </div>

    <!-- GROUP TYPES -->
    <div class="reveal">
      <div class="section-label">Group Types</div>
      <h2 class="display-sm text-navy-800 mb-6">Types of Life Groups</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {groupTypes.map((g, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-base font-black uppercase text-navy-800 mb-1.5" style="letter-spacing: 0.01em;">{g.name}</h3>
            <p class="text-sm text-stone-500 leading-relaxed">{g.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
