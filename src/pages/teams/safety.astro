---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamHero from '../../components/TeamHero.astro';
import TeamResources from '../../components/TeamResources.astro';

const roles = [
  {
    title: 'Medical Team',
    desc: 'Positioned and available during every service, ready to respond to any medical need. Responds quickly and calmly using their training when a medical situation arises. Coordinates with emergency services when needed and reports to the Safety Team Lead.',
    win: 'Anyone who has a medical need at City Church receives immediate, calm, and competent care.',
  },
  {
    title: 'Security',
    desc: 'Monitors entrances, parking areas, and the building during services and events. Responds to any security concerns calmly, professionally, and with the least escalation necessary. Knows the emergency response protocols and coordinates with local authorities when needed.',
    win: 'City Church is a safe, secure environment where families and guests feel completely comfortable.',
  },
];



const expectations = [
  'Arrive before the service begins — safety coverage must be in place before doors open.',
  'Know the emergency response protocols; be ready to act without hesitation.',
  'Respond to situations calmly and professionally — your composure sets the tone.',
  'Use the least escalation necessary in any situation.',
  'Communicate clearly with your team throughout every service.',
  'Never draw attention unless a situation requires it — safety should be felt, not seen.',
  'Background check required. All medical team members must have relevant certifications.',
];
---

<BaseLayout title="Safety Team" description="Ensuring City Church Lufkin is one of the safest places in Lufkin — for every family, guest, and team member.">
  <TeamHero
    title="Safety Team"
    emoji="🛡️"
    subtitle="Ensuring City Church is one of the safest places in Lufkin — for every family, guest, and team member."
    gradientEnd="#5C1A1A"
    patternId="dot-safety"
  />

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The Safety Team works behind the scenes every Sunday to ensure City Church is one of the safest environments in Lufkin. This team includes trained medical personnel ready to respond to any health emergency, and security volunteers who monitor the building and grounds with calm professionalism. Our goal is simple: every family should feel completely at ease when they walk through our doors. Safety should be felt, not noticed.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>


    <TeamResources team="safety" />

  </div>
</BaseLayout>
