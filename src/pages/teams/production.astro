---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Media Team Lead',
    desc: 'Oversees all Sunday technical production — sound, presentation, livestream, and cameras — ensuring every technical element serves the service. Leads, schedules, and supports all tech team members. Ensures all systems are checked, operational, and ready before every service. Problem-solves technical issues quickly and communicates proactively.',
    win: 'Every service sounds great, looks great, and the stream is clean. Technical issues never stop the service.',
  },
  {
    title: 'Sound Tech',
    desc: 'Runs front-of-house audio, ensuring every voice and instrument sounds excellent in the room. Sets up, soundchecks, and mixes the service from start to finish. Balances all channels for a clear, warm, and distraction-free mix. Responds to feedback and cues with a servant heart and quick adjustments.',
    win: 'Sound is clear and balanced. People hear every word and every note. Nobody notices the tech — they just experience great worship.',
  },
  {
    title: 'Presentation Operator',
    desc: 'Manages all slides during the service — worship lyrics, announcements, sermon notes, and graphics — with accuracy and flow. Builds and reviews all ProPresenter slides before the service. Runs slides accurately and in sync with the speaker and worship leader throughout the service. Stays one step ahead at all times.',
    win: 'Every lyric, slide, and graphic is on screen at the right moment. Nobody ever loses the words.',
  },
  {
    title: 'Live Stream Director',
    desc: 'Ensures our online audience experiences City Church services with excellence — managing the stream, directing cameras, and overseeing the digital experience. Sets up, monitors, and manages the live stream from start to finish every Sunday. Directs camera cuts for online viewers, creating an engaging viewing experience.',
    win: 'The stream is clean, consistent, and watchable. Online guests feel like they\'re in the room with us.',
  },
  {
    title: 'Camera Operator',
    desc: 'Captures the service on video, providing clean and well-framed footage for the live stream and recordings. Operates their assigned camera with steady, intentional framing throughout the service. Follows direction from the Live Stream Director and stays responsive to calls. Arrives early and is ready before the service begins.',
    win: 'Every shot is clean and intentional. The live stream and recordings look professional and represent City Church well.',
  },
];

const trainingVideos = [
  { title: 'Media Team Orientation' },
  { title: 'Sound Tech Basics' },
  { title: 'ProPresenter Operator Training' },
  { title: 'Livestream Setup & Monitoring' },
  { title: 'Camera Operation Guide' },
];

const expectations = [
  'Arrive at least 60 minutes before service for full setup and soundcheck.',
  'Know your gear — show up ready to operate, not to learn.',
  'Communicate clearly and calmly with the worship team and leadership.',
  'No distractions at your station during service — full focus required.',
  'Run tech as worship — your role is spiritual, not just technical.',
  'Problem-solve issues quickly and communicate proactively to the Media Team Lead.',
  'Document any equipment issues and report them promptly.',
];
---

<BaseLayout title="Media Team" description="Running audio, video, presentation, and livestream so nothing gets in the way of the message at City Church Lufkin.">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #1A2E5C 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-prod" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-prod)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">🎛️ Media Team</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Running audio, video, presentation, and livestream so nothing gets in the way of the message.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        The Media Team makes sure every Sunday sounds great, looks great, and the stream is clean. We handle sound, presentation, cameras, and the live stream — and every one of those roles is an act of worship. When the tech is invisible, the message gets through. When it's not, it's a distraction. That's the standard we hold. We are the team that makes sure what happens in the room also reaches every person watching online, and that every person in the building can hear the Word with clarity.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
