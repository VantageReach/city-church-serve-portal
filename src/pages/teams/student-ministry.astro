---
import BaseLayout from '../../layouts/BaseLayout.astro';

const roles = [
  {
    title: 'Student Ministry Leader',
    desc: 'Leads City Students — creating a fun, safe, and spiritually rich environment where Jr High and High School students encounter Jesus, build real friendships, and grow in their faith. Plans and leads weekly student ministry gatherings with energy, intentionality, and great content. Recruits and develops student ministry volunteers to build and sustain a healthy team. Builds genuine relationships with students and their families, walking with them through the highs and lows of adolescence.',
    win: 'Students show up because they want to — not because their parents make them. They\'re growing in faith, building real friendships, and finding their place.',
  },
  {
    title: 'Student Ministry Volunteer',
    desc: 'Supports the Student Ministry Leader in creating a safe, fun, and welcoming environment for Jr High and High School students. Builds genuine relationships with students, shows up consistently, and helps facilitate gatherings with energy and care. Assists with logistics, activities, and small group moments that help students grow in their faith.',
    win: 'Students feel genuinely known and cared for by the adults in the room. The team is healthy, the environment is safe, and students keep coming back.',
  },
];

const trainingVideos = [
  { title: 'Student Ministry Orientation' },
  { title: 'Safe Church Policies for Student Ministry' },
  { title: 'Building Relationships with Teenagers' },
  { title: 'Leading Small Group Discussions' },
];

const expectations = [
  'Background check required before serving with students — no exceptions.',
  'Two-adult rule applies: two unrelated adults must always be present with students.',
  'Show up consistently — students need reliable adults, not sporadic ones.',
  'Build genuine relationships — learn their names, their stories, their struggles.',
  'Communicate proactively with the Student Ministry Leader about student needs.',
  'Model a life worth following — what you carry into the room matters.',
  'Maintain appropriate boundaries and follow all safe church policies.',
];
---

<BaseLayout title="Student Ministry" description="Reaching Jr High and High School students at City Church Lufkin with the love of Jesus.">
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #3A2E5C 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-students" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-students)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Teams
      </a>
      <div class="section-label">Serve Team</div>
      <h1 class="display-lg text-white mt-2">⚡ Student Ministry</h1>
      <p class="mt-4 text-lg text-white/60 max-w-xl">Creating a fun, safe, and spiritually rich environment where Jr High and High School students encounter Jesus and find their place.</p>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <div class="reveal">
      <div class="section-label">About This Team</div>
      <h2 class="display-sm text-navy-800 mb-4">Who We Are</h2>
      <p class="text-stone-600 leading-relaxed">
        City Students is our Jr High and High School ministry — and it matters more than almost anything we do. Adolescence is one of the most formative seasons of a person's life, and we believe the church should be the best place in Lufkin for a teenager to spend their time. The Student Ministry team creates environments where students encounter Jesus, build genuine friendships, and find a place where they truly belong. If you love teenagers and want to make a difference in the next generation, this team is for you.
      </p>
    </div>

    <div class="reveal">
      <div class="section-label">Volunteer Standards</div>
      <h2 class="display-sm text-navy-800 mb-6">Expectations</h2>
      <ul class="space-y-3">
        {expectations.map((item, i) => (
          <li class={`flex items-start gap-3 reveal delay-${(i + 1) * 100}`}>
            <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style="background: #8CC640;">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-stone-700 leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="reveal">
      <div class="section-label">Positions</div>
      <h2 class="display-sm text-navy-800 mb-6">Team Roles</h2>
      <div class="space-y-4">
        {roles.map((role, i) => (
          <div class={`card p-6 reveal delay-${(i + 1) * 100}`}>
            <h3 class="font-display text-lg font-black uppercase text-navy-800 mb-2" style="letter-spacing: 0.01em;">{role.title}</h3>
            <p class="text-sm text-stone-500 leading-relaxed mb-3">{role.desc}</p>
            <p class="text-xs text-brand-green-dark font-semibold italic">The Win: {role.win}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal">
      <div class="section-label">Training</div>
      <h2 class="display-sm text-navy-800 mb-6">Training Videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {trainingVideos.map((video, i) => (
          <div class={`card p-5 reveal delay-${(i + 1) * 100}`}>
            <div class="mb-3 flex items-center justify-center rounded-lg aspect-video w-full" style="background: #f0f0f0;">
              <div class="text-center">
                <div class="mb-2 flex h-12 w-12 mx-auto items-center justify-center rounded-full" style="background: rgba(140,198,64,0.15);">
                  <svg class="w-6 h-6" fill="none" stroke="#8CC640" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <p class="text-xs text-stone-400 font-medium">Video coming soon</p>
              </div>
            </div>
            <h4 class="font-semibold text-navy-800 text-sm">{video.title}</h4>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-stone-400 italic">Training videos will be added here as YouTube links. Check back soon.</p>
    </div>

  </div>
</BaseLayout>
