---
import BaseLayout from '../layouts/BaseLayout.astro';

const pillars = ['Hope', 'Community', 'Purpose', 'Impact'];

const values = [
  'Love Is Our Motive',
  'God\'s Presence Is Our Passion',
  'Joy Is Our Expression',
  'Community Is Our Commitment',
  'Serving Is Our Privilege',
  'Excellence Is Our Worship',
  'Generosity Is Our Way',
];
---

<BaseLayout title="Our DNA" description="The vision, values, and mission behind everything City Church Lufkin does.">

  <!-- HERO -->
  <section class="relative overflow-hidden py-20" style="background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, #1A2E5C 100%);">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dot-grid-dna" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dot-grid-dna)"/>
    </svg>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="section-label">Who We Are</div>
      <h1 class="display-lg text-white mt-2">Our <span style="color: #8CC640;">DNA</span></h1>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <!-- VISION -->
    <div class="reveal">
      <div class="section-label">City Church Vision</div>
      <div class="rounded-2xl p-8 sm:p-12" style="background: #101B2E;">
        <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color: rgba(255,255,255,0.35);">We Exist To</p>
        <p class="font-display text-3xl sm:text-4xl lg:text-5xl font-black uppercase leading-tight text-white" style="letter-spacing: 0.01em;">
          Lead People to Full Lives in Christ.
        </p>
      </div>
    </div>

    <!-- MISSIONAL PILLARS -->
    <div class="reveal">
      <div class="section-label">Missional Pillars</div>
      <h2 class="display-sm text-navy-800 mb-8">How We Pursue the Vision</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {pillars.map((pillar, i) => (
          <div class={`rounded-2xl p-6 text-center reveal delay-${(i + 1) * 100}`} style="background: #101B2E;">
            <div class="font-display text-4xl font-black uppercase text-white mb-1" style="letter-spacing: 0.01em;">{pillar}</div>
            <div class="w-8 h-0.5 mx-auto mt-3 rounded-full" style="background: #8CC640;"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- VALUES -->
    <div class="reveal">
      <div class="section-label">City Church Values</div>
      <h2 class="display-sm text-navy-800 mb-8">What We Believe About How We Do This</h2>
      <div class="space-y-3">
        {values.map((value, i) => {
          const [firstWord, ...rest] = value.split(' ');
          return (
            <div
              class={`flex items-center gap-5 rounded-xl border border-stone-200 bg-white px-6 py-5 reveal delay-${Math.min((i + 1) * 100, 500)}`}
              style="box-shadow: 0 1px 4px rgba(16,27,46,0.05);"
            >
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg font-display text-xs font-black text-white" style="background: #8CC640;">
                {String(i + 1).padStart(2, '0')}
              </div>
              <p class="font-display text-xl font-black uppercase text-navy-800" style="letter-spacing: 0.01em;">
                <span style="color: #8CC640;">{firstWord}</span>{' '}{rest.join(' ')}
              </p>
            </div>
          );
        })}
      </div>
    </div>

  </div>

</BaseLayout>
