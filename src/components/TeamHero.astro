---
interface Props {
  title: string;
  emoji: string;
  subtitle: string;
  gradientEnd: string;
  patternId: string;
  label?: string;
}
const { title, emoji, subtitle, gradientEnd, patternId, label = 'Serve Team' } = Astro.props;
---

<section class="relative overflow-hidden flex items-center" style={`background: linear-gradient(160deg, #0A1220 0%, #101B2E 60%, ${gradientEnd} 100%); min-height: 46vh;`}>

  <svg class="absolute inset-0 w-full h-full pointer-events-none" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <pattern id={patternId} x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
        <rect x="14" y="14" width="4" height="4" rx="1" fill="#8CC640" opacity="0.10" transform="rotate(45 16 16)"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill={`url(#${patternId})`}/>
  </svg>

  <!-- Radial glow -->
  <div class="absolute pointer-events-none" style="top: -60px; left: -60px; width: 360px; height: 360px; background: radial-gradient(circle, rgba(140,198,64,0.14) 0%, transparent 70%);"></div>

  <!-- Left green bar -->
  <div class="absolute left-0 top-0 bottom-0 w-1" style="background: linear-gradient(180deg, transparent, #8CC640 30%, #8CC640 70%, transparent);"></div>

  <!-- Watermark -->
  <div class="absolute inset-0 flex items-center justify-end pointer-events-none overflow-hidden" aria-hidden="true">
    <span class="font-display font-black uppercase text-white select-none"
          style="font-size: clamp(5rem, 16vw, 13rem); letter-spacing: -0.02em; opacity: 0.028; line-height: 1; padding-right: 1.5rem; white-space: nowrap;">
      {title}
    </span>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 sm:px-10 lg:px-16 py-20 w-full">
    <a href="/teams/" class="inline-flex items-center gap-1.5 text-sm text-white/50 hover:text-white/80 transition-colors duration-200 mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      All Teams
    </a>

    <div class="flex items-center gap-3 mb-5">
      <div class="h-px w-10 rounded-full" style="background: #8CC640;"></div>
      <span class="text-xs font-bold uppercase tracking-widest" style="color: rgba(140,198,64,0.8);">{label}</span>
    </div>

    <h1 class="font-display font-black uppercase leading-none text-white mb-5"
        style="font-size: clamp(2.8rem, 7vw, 5.5rem); letter-spacing: 0.01em;">
      <span class="mr-3">{emoji}</span>{title}
    </h1>
    <p class="text-lg max-w-xl leading-relaxed" style="color: rgba(255,255,255,0.60);">{subtitle}</p>
  </div>
</section>
