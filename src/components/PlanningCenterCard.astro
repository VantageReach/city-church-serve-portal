---
interface Props {
  type: 'services' | 'app' | 'mxq';
}

const { type } = Astro.props;

const data = {
  services: {
    name: 'Planning Center Services',
    desc: 'Schedule & sign up for serve slots',
    ios: 'https://itunes.apple.com/us/app/planning-center-services/id327370808?mt=8',
    android: 'https://play.google.com/store/apps/details?id=com.ministrycentered.PlanningCenter&hl=en',
    web: 'https://services.planningcenteronline.com' as string | null,
  },
  app: {
    name: 'Planning Center App',
    desc: 'People, groups, check-ins & more',
    ios: 'https://apps.apple.com/us/app/planning-center-tasks/id6751657545',
    android: 'https://play.google.com/store/apps/details?id=com.planningcenter.app&hl=en_US',
    web: 'https://app.planningcenteronline.com' as string | null,
  },
  mxq: {
    name: 'MX-Q',
    desc: 'Personal monitor mix control for Behringer Wing',
    ios: 'https://apps.apple.com/us/app/wing-q/id1519012379',
    android: 'https://play.google.com/store/apps/details?id=musictribe.q.wapp&hl=en',
    web: null,
  },
}[type];
---

<div class="card p-5">
  <!-- App icon + name -->
  <div class="flex items-center gap-3 mb-4">
    {type === 'mxq' ? (
      <!-- MX-Q — black with yellow Q -->
      <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
        <rect width="44" height="44" rx="10" fill="#0A0A0A"/>
        <text x="22" y="31" text-anchor="middle" fill="#F5C400" font-size="28" font-weight="900" font-family="Arial Black, Impact, sans-serif">Q</text>
      </svg>
    ) : type === 'app' ? (
      <!-- Planning Center App — blue gradient -->
      <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
        <rect width="44" height="44" rx="10" fill="url(#pc-app-grad)"/>
        <defs>
          <linearGradient id="pc-app-grad" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
            <stop stop-color="#5B73F5"/>
            <stop offset="1" stop-color="#3A4FD8"/>
          </linearGradient>
        </defs>
        <text x="22" y="30" text-anchor="middle" fill="white" font-size="22" font-weight="900" font-family="Arial, sans-serif">P</text>
      </svg>
    ) : (
      <!-- Planning Center Services — green icon with list -->
      <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
        <rect width="44" height="44" rx="10" fill="url(#pc-svc-grad)"/>
        <defs>
          <linearGradient id="pc-svc-grad" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
            <stop stop-color="#6DC05A"/>
            <stop offset="1" stop-color="#4A9939"/>
          </linearGradient>
        </defs>
        <!-- List icon -->
        <rect x="13" y="14" width="5" height="5" rx="1.5" fill="white"/>
        <rect x="21" y="15.5" width="10" height="2" rx="1" fill="white" opacity="0.9"/>
        <rect x="13" y="21" width="5" height="5" rx="1.5" fill="white"/>
        <rect x="21" y="22.5" width="10" height="2" rx="1" fill="white" opacity="0.9"/>
        <rect x="13" y="28" width="5" height="5" rx="1.5" fill="white"/>
        <rect x="21" y="29.5" width="10" height="2" rx="1" fill="white" opacity="0.9"/>
      </svg>
    )}
    <div>
      <p class="font-semibold text-navy-800 text-sm leading-snug">{data.name}</p>
      <p class="text-xs text-stone-400 mt-0.5">{data.desc}</p>
    </div>
  </div>

  <!-- Download badges -->
  <div class="flex flex-wrap gap-2 mb-3">
    <!-- App Store badge -->
    <a
      href={data.ios}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 rounded-lg px-3 py-2 transition-opacity duration-200 hover:opacity-80"
      style="background: #1C1C1E; min-width: 128px;"
    >
      <svg width="18" height="22" viewBox="0 0 18 22" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14.97 11.648c-.02-2.302 1.88-3.418 1.965-3.47-1.072-1.569-2.737-1.783-3.325-1.804-1.408-.143-2.762.831-3.477.831-.727 0-1.838-.814-3.026-.792C5.5 6.436 3.9 7.39 3.02 8.895 1.213 11.96 2.57 16.5 4.31 18.983c.866 1.216 1.887 2.579 3.228 2.529 1.302-.052 1.791-.835 3.365-.835 1.561 0 2.013.835 3.38.806 1.399-.024 2.281-1.228 3.13-2.456a11.2 11.2 0 001.417-2.839c-.032-.014-2.826-1.082-2.86-4.54zM12.645 3.5c.7-.863 1.176-2.044 1.045-3.236-1.01.044-2.268.68-3 1.525-.647.748-1.22 1.963-1.068 3.117 1.135.086 2.302-.577 3.023-1.406z" fill="white"/>
      </svg>
      <div>
        <div style="font-size: 9px; color: rgba(255,255,255,0.75); line-height: 1; font-family: system-ui, sans-serif;">Download on the</div>
        <div style="font-size: 15px; color: white; font-weight: 600; line-height: 1.2; font-family: system-ui, sans-serif;">App Store</div>
      </div>
    </a>

    <!-- Google Play badge -->
    <a
      href={data.android}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 rounded-lg px-3 py-2 transition-opacity duration-200 hover:opacity-80"
      style="background: white; border: 1px solid #d4d4d4; min-width: 138px;"
    >
      <svg width="20" height="22" viewBox="0 0 20 22" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1.077.64L11.2 11 1.077 21.36A1.5 1.5 0 01.5 20.15V1.85A1.5 1.5 0 011.077.64z" fill="#EA4335"/>
        <path d="M14.8 7.4L2.9.28a1.5 1.5 0 00-.747-.196.5.5 0 00-.076.006L11.2 11l3.6-3.6z" fill="#FBBC04"/>
        <path d="M14.8 14.6L11.2 11l-9.124 9.91a.5.5 0 00.076.006 1.5 1.5 0 00.748-.197L14.8 14.6z" fill="#34A853"/>
        <path d="M19.15 9.15l-4.35-2.55L11.2 11l3.6 3.6 4.35-2.55a1.502 1.502 0 000-2.9z" fill="#4285F4"/>
      </svg>
      <div>
        <div style="font-size: 9px; color: #555; line-height: 1; font-family: system-ui, sans-serif; letter-spacing: 0.03em;">GET IT ON</div>
        <div style="font-size: 15px; color: #1a1a1a; font-weight: 600; line-height: 1.2; font-family: system-ui, sans-serif;">Google Play</div>
      </div>
    </a>
  </div>

  <!-- Web link (only when available) -->
  {data.web && (
  <a
    href={data.web}
    target="_blank"
    rel="noopener"
    class="inline-flex items-center gap-1 text-xs font-semibold transition-opacity duration-200 hover:opacity-70"
    style="color: #6FA32E;"
  >
    Also available on the web
    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
  </a>
  )}
</div>
